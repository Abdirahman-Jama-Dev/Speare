{
  "name": "speare",
  "version": "0.1.0",
  "description": "YAML-driven Playwright test framework",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npx tsc -p tsconfig.build.json && cp -r src/schema/schemas dist/schema/schemas",
    "dev": "tsc --watch",
    "setup": "npm run build && npx playwright install --with-deps chromium",
    "test": "node dist/cli/index.js run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "validate": "node dist/cli/index.js validate",
    "merge-reports": "node dist/cli/index.js merge-reports",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.9.1",
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.44.0",
    "ajv": "^8.16.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^9.6.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0",
    "jsonpath-plus": "^9.0.0",
    "mssql": "^11.0.0",
    "mysql2": "^3.9.8",
    "pg": "^8.12.0",
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/js-yaml": "^4.0.9",
    "@types/mssql": "^9.1.5",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.3.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
